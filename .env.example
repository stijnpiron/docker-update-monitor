# Docker Hub credentials
# Preferred auth: use a Personal Access Token (PAT) instead of your password.
# Generate one at: https://app.docker.com/settings/personal-access-tokens
DOCKERHUB_USERNAME=myusername
DOCKERHUB_PASSWORD=my_personal_access_token

# GitHub PAT with read:packages scope — needed for ghcr.io images
# Generate one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Docker socket GID (find with: stat -c '%g' /var/run/docker.sock)
DOCKER_GID=999

# Telegram notification channel (optional)
# TELEGRAM_BOT_TOKEN=123456789:ABCDefgh...
# TELEGRAM_CHAT_ID=-1001234567890
